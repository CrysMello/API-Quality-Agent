{
  "openapi": "3.0.3",
  "info": { "title": "Pets API", "version": "1.0.0" },
  "paths": {
    "/pets": {
      "get": {
        "operationId": "listPets",
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "operationId": "createPet",
        "responses": { "201": { "description": "Criado" } }
      }
    },
    "/pets/{petId}": {
      "get": {
        "operationId": "getPet",
        "parameters": [
          {
            "name": "petId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}
